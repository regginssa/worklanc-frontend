# App URL used for OAuth redirect URIs (no trailing slash)
APP_URL=http://localhost:3000

# Backend API (browser)
NEXT_PUBLIC_BACKEND_URL=http://localhost:5001

# Shared secret between Next.js OAuth callbacks and Express /api/auth/oauth
# Generate: openssl rand -hex 32
OAUTH_INTERNAL_SECRET=

# Google OAuth (server-only — do not use NEXT_PUBLIC_)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign In (server-only)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# PEM private key contents (use \n for newlines in .env.local)
APPLE_PRIVATE_KEY=
